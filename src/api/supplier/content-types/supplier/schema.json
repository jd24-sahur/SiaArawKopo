{
  "kind": "collectionType",
  "collectionName": "suppliers",
  "info": {
    "singularName": "supplier",
    "pluralName": "suppliers",
    "displayName": "Suppliers"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "SupplierName": {
      "type": "string",
      "required": true
    },
    "ContactPerson": {
      "type": "string",
      "required": true
    },
    "PhoneNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "EmailAddress": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "LicenseNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "purchase_orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::purchase-order.purchase-order",
      "mappedBy": "supplier"
    }
  }
}
