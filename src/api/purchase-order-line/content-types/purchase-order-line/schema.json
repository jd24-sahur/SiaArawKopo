  },
  "pluginOptions": {},
  "attributes": {
    "QuantityOrdered": {
      "type": "biginteger",
      "required": true
    },
    "UnitPriceAtOrder": {
      "type": "decimal",
      "required": true
    },
    "LineTotal": {
      "type": "integer",
      "required": true
    },
    "RecievedStatus": {
      "type": "boolean"
    },
    "medicine": {
