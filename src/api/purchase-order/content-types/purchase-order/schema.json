{
  "kind": "collectionType",
  "collectionName": "purchase_orders",
  "info": {
    "singularName": "purchase-order",
    "pluralName": "purchase-orders",
    "displayName": "Purchase_Orders"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "OrderDate": {
      "type": "date"
    },
    "TotalAmount": {
      "type": "integer",
      "required": true
    },
    "PaymentStatus": {
      "type": "boolean",
      "required": true
    },
    "RecievedDate": {
      "type": "boolean"
    },
    "purchase_order_lines": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::purchase-order-line.purchase-order-line",
      "mappedBy": "purchase_order"
    },
    "supplier": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::supplier.supplier",
      "inversedBy": "purchase_orders"
    }
  }
}
